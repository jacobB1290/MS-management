# Web push notifications (VAPID). Generate a keypair once with:
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
# Public key is exposed to the browser (NEXT_PUBLIC_); private key is server-only.
# VAPID_SUBJECT is a mailto: or https: contact URL. Without these, push is off.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@morningstarchurchboise.org

# Demo mode — set to "1" ONLY on a throwaway demo/preview deployment. When on,
# the app runs entirely on in-memory fixtures (no Supabase, Twilio, or SendGrid
# calls) and visitors enter by typing `demo` as the email on /login. NEVER set
# this in production: it bypasses real auth. Leave blank/unset everywhere real.
DEMO_MODE=

# Supabase — public (safe to commit only as placeholders)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Login OAuth buttons to show on /login. Comma-separated, only providers you've
# actually enabled in Supabase Auth (otherwise the button errors on tap).
# Supported: google, apple. Leave blank for code-only sign-in.
NEXT_PUBLIC_OAUTH_PROVIDERS=

# Supabase — server-only (NEVER expose to the client bundle)
SUPABASE_SERVICE_ROLE_KEY=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_PHONE_NUMBER=

# Twilio Voice — browser-based outbound calling. All three must be set for the
# Call button to appear; otherwise it stays disabled with a tooltip. Never
# exposed to the browser: the server mints a short-lived Voice access token.
#   - Create an API key + secret in Twilio Console (Account > API keys & tokens
#     > Standard key). The secret is shown ONCE at creation, so copy it then.
#   - Create a TwiML App (Voice > TwiML > TwiML Apps), point its Voice "Request
#     URL" (HTTP POST) at  <APP_BASE_URL>/api/voice/outbound , then paste its
#     SID below. Outbound calls present TWILIO_PHONE_NUMBER as caller ID, so
#     that number must be voice-capable on your account.
TWILIO_API_KEY=
TWILIO_API_SECRET=
TWILIO_TWIML_APP_SID=

# Brevo (email — both 1:1 transactional sends and bulk campaign blasts). Email
# runs in mock mode (logged, not sent) until BREVO_API_KEY is set, so the inbox,
# campaigns, and the Playwright harness all work without a provisioned account.
#   - BREVO_API_KEY: Brevo dashboard → account menu (top-right) → SMTP & API →
#     API Keys → "Generate a new API key". Server-only; never expose to client.
#   - BREVO_FROM_EMAIL / BREVO_FROM_NAME: the verified sender every email goes out
#     as (e.g. newsletter@ms.church). The domain MUST be authenticated in Brevo or
#     it rewrites the From to @brevosend.com. DNS for ms.church lives in VERCEL DNS
#     (nameservers are Vercel), not Cloudflare — the runbook has the exact records.
#   - BREVO_REPLY_TO_EMAIL: where replies land — the Google Workspace mailbox
#     (support@ms.church). Brevo sends; Google receives; humans answer in Gmail.
BREVO_API_KEY=
BREVO_FROM_EMAIL=
BREVO_FROM_NAME=Morning Star Church
BREVO_REPLY_TO_EMAIL=support@ms.church

# Optional. From address for 1:1 PERSONAL email (inbox replies). Defaults to
# BREVO_REPLY_TO_EMAIL (support@) so a personal note comes from a human address,
# not the newsletter sender used for blasts. Must be a Brevo sender on the
# authenticated domain. Campaign blasts always send from BREVO_FROM_EMAIL.
BREVO_PERSONAL_FROM_EMAIL=

# Brevo does NOT sign webhooks, so the marketing webhook is authenticated by this
# shared secret carried in the URL. Configure the Brevo webhook (events:
# unsubscribed, hardBounce, spam) to POST to:
#   <APP_BASE_URL>/api/webhook/brevo?token=<this value>
# A long random string; unset disables the webhook (unsubscribes won't sync back).
BREVO_WEBHOOK_TOKEN=

# Optional. The Brevo contact FOLDER id (Contacts → Folders) that per-campaign
# audience lists are created under. When unset, a folder is created on demand.
BREVO_LIST_FOLDER_ID=
# Optional. Caps a single blast's eligible audience so it stays within Brevo's
# free-tier daily send budget (300/day, shared transactional + campaign).
# Defaults to 300.
BREVO_DAILY_SEND_CAP=300

# Anthropic / Claude — powers AI tag suggestions, reply drafting, inbox triage,
# and "Promote with AI" (Opus reads an event flyer and drafts the campaign).
# Server-only;
# NEVER expose to the client bundle. Leave blank to turn the features off cleanly
# — the UI affordances stay hidden and the endpoints return 503 (no crash). Get a
# key at https://console.anthropic.com/. The model per feature is chosen at
# runtime in Settings > AI models (no redeploy needed).
ANTHROPIC_API_KEY=

# Anthropic Admin API key (sk-ant-admin…) — OPTIONAL, powers the live AI cost +
# usage panel in Settings (real billed amounts from the org Cost/Usage APIs).
# Distinct from the model key above. Without it the panel shows "not configured".
# Create one at https://console.anthropic.com/ under Settings > Admin keys.
ANTHROPIC_ADMIN_KEY=

# Church website the AI knowledge base syncs from — OPTIONAL, defaults to
# https://ms.church. The daily sync reads its sitemap + pages so drafted replies
# can cite real service times, Bible studies, ministries, etc. The drafting model
# decides when to look these up via the lookup_church_info tool.
CHURCH_WEBSITE_URL=https://ms.church

# Google Calendar / Events — the CRM writes events to the church Google Calendar
# (the same calendar ms.church reads to render its public events feed), uploads
# flyer images to Drive, and shares them publicly so the site can show them.
# READS/sync work with just an API key; WRITES (create/edit/delete events +
# upload flyers) need OAuth as the church Google account. Leave all blank to run
# in mock mode: events save locally and "publish" is logged, not pushed live —
# the whole feature + harness still work. Setup: docs/events-google-setup-runbook.md.
#   - GOOGLE_CALENDAR_ID defaults to the church calendar; override to test elsewhere.
#   - The OAuth refresh token needs scopes calendar + drive.file, minted with
#     access_type=offline & prompt=consent. CRITICAL: publish the OAuth consent
#     screen to "In production" first, or the refresh token expires after 7 days.
GOOGLE_CALENDAR_ID=morningstarchurchboise@gmail.com
GOOGLE_CALENDAR_API_KEY=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
# Optional Drive folder to hold flyer images (else they land in My Drive root).
GOOGLE_DRIVE_FOLDER_ID=

# Gmail — two-way email in the CRM. Mirrors the support@ms.church mailbox so a
# contact's thread shows the FULL email conversation (inbound replies + anything
# composed in Gmail), and (Phase 2) can SEND 1:1 through Gmail. A SEPARATE Google
# identity from the calendar above: its OWN OAuth app under support@ms.church.
#   - GOOGLE_GMAIL_CLIENT_ID / SECRET: the dedicated Gmail OAuth client. Falls back
#     to GOOGLE_OAUTH_CLIENT_ID/SECRET only if unset (the calendar keeps using
#     GOOGLE_OAUTH_* regardless).
#   - GOOGLE_GMAIL_REFRESH_TOKEN: refresh token for the support@ mailbox, minted
#     with gmail.readonly (+ gmail.send for Phase 2). No token → sync + send are
#     no-ops and 1:1 falls back to Brevo (nothing breaks).
#   - GOOGLE_GMAIL_SEND: set to 1 to route 1:1 email THROUGH Gmail (Phase 2). Leave
#     unset until the read-mirror is verified and the token has gmail.send; while
#     off, 1:1 sends via Brevo. Setup: docs/brevo-email-setup-runbook.md.
GOOGLE_GMAIL_CLIENT_ID=
GOOGLE_GMAIL_CLIENT_SECRET=
GOOGLE_GMAIL_REFRESH_TOKEN=
GOOGLE_GMAIL_SEND=
# The mailbox being mirrored / sent from. Defaults to BREVO_REPLY_TO_EMAIL.
GOOGLE_GMAIL_ADDRESS=support@ms.church

# YouTube — the sermon SEO pipeline. Weekly it detects the newest service video
# (via the public RSS feed, no key), downloads its captions, segments the
# transcript with Claude, and — once a human publishes — feeds the chaptered
# transcript to ms.church for SEO. The ONLY credential beyond the Google setup
# above is a refresh token carrying the `youtube.force-ssl` scope, because
# caption download only works AS the channel OWNER. Leave blank to run the
# pipeline up to transcription in mock-fail mode (the monitor shows it waiting).
#   - Easiest path: if the YouTube channel and the calendar above are the SAME
#     Google account, just ADD youtube.force-ssl to the existing OAuth client and
#     re-consent — GOOGLE_OAUTH_REFRESH_TOKEN then covers captions too and you set
#     NOTHING here.
#   - Different account: give the pipeline its own client + token below; it falls
#     back to GOOGLE_OAUTH_* / GOOGLE_OAUTH_CLIENT_* when these are unset.
# Setup + the publish-to-Production gotcha: docs/sermons-youtube-setup-runbook.md.
GOOGLE_YOUTUBE_CLIENT_ID=
GOOGLE_YOUTUBE_CLIENT_SECRET=
GOOGLE_YOUTUBE_REFRESH_TOKEN=
# Optional. The "service uploads" playlist the pipeline watches. Defaults to the
# church playlist (kept identical to ms.church's src/config.ts YOUTUBE_CONFIG).
YOUTUBE_PLAYLIST_ID=PLHs3usNpG0bZHnAJlIpwBtkbnd7xDCeRC

# Public form HMAC (signs requests from website → CRM)
PUBLIC_FORM_HMAC_SECRET=

# Cron shared secret — protects the GitHub Actions cron endpoints (/api/cron/*,
# e.g. the campaign worker and the daily knowledge sync). Use the same value as
# the CRON_SECRET GitHub Actions secret. Fail-closed: blank disables those crons.
CRON_SECRET=

# App
APP_BASE_URL=http://localhost:3000

# CAN-SPAM physical mailing address for bulk email. With Brevo this is set in the
# campaign template footer / Brevo sender settings (the runbook covers it); kept
# here as the canonical value to paste into Brevo.
PHYSICAL_MAILING_ADDRESS=3080 N Wildwood St, Boise, ID 83713
