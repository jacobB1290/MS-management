# Web push notifications (VAPID). Generate a keypair once with:
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
# Public key is exposed to the browser (NEXT_PUBLIC_); private key is server-only.
# VAPID_SUBJECT is a mailto: or https: contact URL. Without these, push is off.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@morningstarchurchboise.org

# Demo mode — set to "1" ONLY on a throwaway demo/preview deployment. When on,
# the app runs entirely on in-memory fixtures (no Supabase, Twilio, or SendGrid
# calls) and visitors enter by typing `demo` as the email on /login. NEVER set
# this in production: it bypasses real auth. Leave blank/unset everywhere real.
DEMO_MODE=

# Supabase — public (safe to commit only as placeholders)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Login OAuth buttons to show on /login. Comma-separated, only providers you've
# actually enabled in Supabase Auth (otherwise the button errors on tap).
# Supported: google, apple. Leave blank for code-only sign-in.
NEXT_PUBLIC_OAUTH_PROVIDERS=

# Supabase — server-only (NEVER expose to the client bundle)
SUPABASE_SERVICE_ROLE_KEY=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_PHONE_NUMBER=

# Twilio Voice — browser-based outbound calling. All three must be set for the
# Call button to appear; otherwise it stays disabled with a tooltip. Never
# exposed to the browser: the server mints a short-lived Voice access token.
#   - Create an API key + secret in Twilio Console (Account > API keys & tokens
#     > Standard key). The secret is shown ONCE at creation, so copy it then.
#   - Create a TwiML App (Voice > TwiML > TwiML Apps), point its Voice "Request
#     URL" (HTTP POST) at  <APP_BASE_URL>/api/voice/outbound , then paste its
#     SID below. Outbound calls present TWILIO_PHONE_NUMBER as caller ID, so
#     that number must be voice-capable on your account.
TWILIO_API_KEY=
TWILIO_API_SECRET=
TWILIO_TWIML_APP_SID=

# SendGrid
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_FROM_NAME=Morning Star Church
SENDGRID_UNSUBSCRIBE_GROUP_ID=
# Signed Event Webhook (opens/bounces/unsubscribes) public key.
SENDGRID_WEBHOOK_PUBLIC_KEY=

# Two-way email (inbox). INBOUND_EMAIL_DOMAIN is a subdomain whose MX points at
# SendGrid Inbound Parse (mx.sendgrid.net), e.g. reply.ms.church. Outbound 1:1
# replies set Reply-To: reply+<contactId>@<this domain> so the contact's reply
# threads back into the inbox. Leave blank to send-only (no auto-threading).
INBOUND_EMAIL_DOMAIN=
# Shared secret guarding the unsigned Inbound Parse webhook. Configure the Parse
# destination as <APP_BASE_URL>/api/webhook/sendgrid-inbound?token=<this value>.
SENDGRID_INBOUND_TOKEN=
# Signs the one-click List-Unsubscribe links on outbound 1:1 email so they can't
# be guessed. Optional — falls back to PUBLIC_FORM_HMAC_SECRET when unset.
EMAIL_UNSUBSCRIBE_SECRET=

# Anthropic / Claude — powers AI tag suggestions and reply drafting. Server-only;
# NEVER expose to the client bundle. Leave blank to turn the features off cleanly
# — the UI affordances stay hidden and the endpoints return 503 (no crash). Get a
# key at https://console.anthropic.com/. The model per feature is chosen at
# runtime in Settings > AI models (no redeploy needed).
ANTHROPIC_API_KEY=

# Anthropic Admin API key (sk-ant-admin…) — OPTIONAL, powers the live AI cost +
# usage panel in Settings (real billed amounts from the org Cost/Usage APIs).
# Distinct from the model key above. Without it the panel shows "not configured".
# Create one at https://console.anthropic.com/ under Settings > Admin keys.
ANTHROPIC_ADMIN_KEY=

# Church website the AI knowledge base syncs from — OPTIONAL, defaults to
# https://ms.church. The daily sync reads its sitemap + pages so drafted replies
# can cite real service times, Bible studies, ministries, etc. The drafting model
# decides when to look these up via the lookup_church_info tool.
CHURCH_WEBSITE_URL=https://ms.church

# Google Calendar / Events — the CRM writes events to the church Google Calendar
# (the same calendar ms.church reads to render its public events feed), uploads
# flyer images to Drive, and shares them publicly so the site can show them.
# READS/sync work with just an API key; WRITES (create/edit/delete events +
# upload flyers) need OAuth as the church Google account. Leave all blank to run
# in mock mode: events save locally and "publish" is logged, not pushed live —
# the whole feature + harness still work. Setup: docs/events-google-setup-runbook.md.
#   - GOOGLE_CALENDAR_ID defaults to the church calendar; override to test elsewhere.
#   - The OAuth refresh token needs scopes calendar + drive.file, minted with
#     access_type=offline & prompt=consent. CRITICAL: publish the OAuth consent
#     screen to "In production" first, or the refresh token expires after 7 days.
GOOGLE_CALENDAR_ID=morningstarchurchboise@gmail.com
GOOGLE_CALENDAR_API_KEY=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
# Optional Drive folder to hold flyer images (else they land in My Drive root).
GOOGLE_DRIVE_FOLDER_ID=

# Public form HMAC (signs requests from website → CRM)
PUBLIC_FORM_HMAC_SECRET=

# Cron shared secret — protects the GitHub Actions cron endpoints (/api/cron/*,
# e.g. the campaign worker and the daily knowledge sync). Use the same value as
# the CRON_SECRET GitHub Actions secret. Fail-closed: blank disables those crons.
CRON_SECRET=

# App
APP_BASE_URL=http://localhost:3000

# CAN-SPAM physical mailing address (required in bulk email)
PHYSICAL_MAILING_ADDRESS=3080 N Wildwood St, Boise, ID 83713
